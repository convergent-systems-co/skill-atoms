---
import Base from "../../layouts/Base.astro";
import catalog from "../../../public/exports/catalog.json";

export function getStaticPaths() {
  return catalog.compositions.map((composition: any) => ({
    // composition.id is namespaced "<type>/<slug>"; strip the leading segment
    // so the single [id] param has no embedded slash (which breaks the build).
    params: { id: composition.id.replace(/^[^/]+\//, "") },
    props: { composition },
  }));
}

const { composition } = Astro.props;
const refs = composition.references ?? {};

type Ref = { ref: string; version: string };
const sections: Array<{ label: string; values: Ref[] }> = [
  { label: "Skill", values: refs.skill ? [refs.skill] : [] },
  { label: "Input schema", values: refs.input_schema ? [refs.input_schema] : [] },
  { label: "Output schema", values: refs.output_schema ? [refs.output_schema] : [] },
  { label: "Trust boundary", values: refs.trust_boundary ? [refs.trust_boundary] : [] },
  { label: "Side effects", values: refs.side_effects ?? [] },
];
---
<Base title={composition.name} description={composition.description}>
  <p><a href="/skills/">← All skills</a></p>
  <h1>{composition.name}</h1>
  <p style="color: var(--muted);">
    <code>skill</code> · <code>v{composition.version}</code>
  </p>

  {composition.description && <p>{composition.description}</p>}

  <h2>References</h2>
  {sections.map(section => section.values.length > 0 && (
    <div style="margin-bottom: 1.5rem;">
      <h3 style="margin-bottom: 0.5rem;">{section.label}</h3>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        {section.values.map((r: Ref) => (
          <code style="background: #f4ece4; padding: 0.25rem 0.75rem; border-radius: 0.25rem;">{r.ref}@{r.version}</code>
        ))}
      </div>
    </div>
  ))}

  <h2>Raw composition</h2>
  <p><a href={`/skills/${composition.id}.json`}>/skills/{composition.id}.json</a> · <a href="/schemas/composition-v1.json">schema</a></p>
</Base>
