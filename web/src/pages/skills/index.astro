---
import Base from "../../layouts/Base.astro";
import catalog from "../../../public/exports/catalog.json";

const compositions = catalog.compositions.slice().sort((a: any, b: any) => a.id.localeCompare(b.id));
---
<Base title="Skills" description="Skill compositions — bundled invocation contracts, prompt material, and trust boundaries.">
  <h1>Skills</h1>
  <p>{compositions.length} skill composition{compositions.length === 1 ? "" : "s"} — each bundles atoms into a complete, invocable skill definition.</p>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr)); gap: 1rem; margin-top: 2rem;">
    {compositions.map((c: any) => (
      <article style="border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem; background: var(--card);">
        <header style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; margin-bottom: 0.5rem;">
          <h3 style="margin: 0;"><a href={`/skills/${c.id}/`}>{c.name}</a></h3>
          <code style="color: var(--muted); font-size: 0.75rem;">v{c.version}</code>
        </header>
        {c.description && <p style="margin: 0.5rem 0; color: var(--muted);">{c.description}</p>}
      </article>
    ))}
    {compositions.length === 0 && <p style="color: var(--muted);">No skill compositions yet. Skill schema definition is in progress (sub-project 2).</p>}
  </div>
</Base>
