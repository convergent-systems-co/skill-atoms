---
const title = "skill-atoms";
const tagline = "Catalog of AI skills — convergent-systems.co atoms ecosystem.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={tagline} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --bg: #0b0d10;
        --fg: #e8e8e6;
        --muted: #7a8088;
        --accent: #8be9fd;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
      body {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
        line-height: 1.5;
      }
      main {
        max-width: 42rem;
        text-align: left;
      }
      h1 {
        font-size: clamp(2.5rem, 8vw, 4rem);
        margin: 0 0 0.5rem;
        font-weight: 600;
        letter-spacing: -0.03em;
      }
      .tagline { color: var(--muted); margin: 0 0 2rem; font-size: 1.125rem; }
      .status {
        border: 1px solid #1f242a;
        border-left: 3px solid var(--accent);
        padding: 1rem 1.25rem;
        background: #11141a;
        border-radius: 4px;
      }
      .status p { margin: 0 0 0.5rem; }
      .status p:last-child { margin-bottom: 0; }
      code {
        background: #1a1f26;
        padding: 0.1em 0.4em;
        border-radius: 3px;
        font-size: 0.9em;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      footer {
        color: var(--muted);
        margin-top: 3rem;
        font-size: 0.875rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p class="tagline">{tagline}</p>
      <div class="status">
        <p><strong>Status:</strong> bootstrap. Catalog is empty pending the canonical <code>skill</code> schema in <a href="https://github.com/convergent-systems-co/schema-atoms">schema-atoms</a>.</p>
        <p>Source: <a href="https://github.com/convergent-systems-co/skill-atoms">github.com/convergent-systems-co/skill-atoms</a></p>
      </div>
      <footer>
        Part of the <a href="https://github.com/convergent-systems-co/atoms">atoms ecosystem</a>.
        Apache-2.0.
      </footer>
    </main>
  </body>
</html>
